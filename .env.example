# 🐳 Pixel Agents - Environment Configuration

# Gemini Authentication Mode
# Options: google_login (requires ~/.gemini credentials) or api_key
GEMINI_AUTH_MODE=google_login

# Gemini API Key (only used if GEMINI_AUTH_MODE=api_key)
# GEMINI_API_KEY=your_api_key_here

# Backend Port (defaults to 3003 if not set)
PORT=3003

# Project Root (defaults to parent of backend folder)
# PROJECT_ROOT=/app

# GHCR Image for production deployment
# GHCR_IMAGE=diopratama/animated-ai-agents
